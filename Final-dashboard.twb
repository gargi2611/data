    <worksheet name='KPI- CSAT'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontsize='10'>CSAT Score</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Support_tickets (Support_tickets)' name='federated.02q4qsv1gwrutx10fvehz1yh184p' />
          </datasources>
          <datasource-dependencies datasource='federated.02q4qsv1gwrutx10fvehz1yh184p'>
            <column caption='Negative Sentiment %' datatype='real' default-format='p0.0%' name='[Calculation_551409497020563471]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [customer_sentiment] = &quot;negative&quot; THEN 1 ELSE 0 END)/COUNT([ticket_id])' />
            </column>
            <column caption='CSAT Score' datatype='real' default-format='p0.0%' name='[Calculation_551409497021263889]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM(IF [customer_sentiment] = &quot;positive&quot; THEN 3&#13;&#10;ELSEIF [customer_sentiment] = &quot;neutral&quot; THEN 2&#13;&#10;ELSE 1 END)/(COUNT([ticket_id])*3))*100' />
            </column>
            <column caption='KPI Traffic Light' datatype='string' name='[Calculation_551409497029922841]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_551409497020563471] &gt; 0.30 THEN &quot;At Risk&quot;&#13;&#10;ELSEIF [Calculation_551409497020563471] &gt; 0.20 THEN &quot;Caution&quot;&#13;&#10;ELSE &quot;Healthy&quot;&#13;&#10;END' />
            </column>
            <column caption='Customer Sentiment' datatype='string' name='[customer_sentiment]' role='dimension' type='nominal' />
            <column caption='Ticket Id' datatype='integer' name='[ticket_id]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_551409497021263889]' derivation='User' name='[usr:Calculation_551409497021263889:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_551409497029922841]' derivation='User' name='[usr:Calculation_551409497029922841:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='color' data-class='total' scope='cols' value='#ffffff' />
            <format attr='font-weight' data-class='total' scope='cols' value='bold' />
            <format attr='font-size' data-class='total' scope='cols' value='36' />
            <format attr='font-size' data-class='subtotal' scope='cols' value='36' />
            <format attr='font-weight' data-class='subtotal' scope='cols' value='bold' />
            <format attr='color' data-class='subtotal' scope='cols' value='#ffffff' />
          </style-rule>
          <style-rule element='table'>
            <format attr='background-color' value='#ffffff' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Text' />
