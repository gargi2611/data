      <aliases enabled='yes' />
      <column caption='Year' datatype='integer' name='[Calculation_551409497014218753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([date])' />
      </column>
      <column caption='Quarter' datatype='string' name='[Calculation_551409497014341634]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;,[date]))' />
      </column>
      <column caption='Month Name' datatype='string' name='[Calculation_551409497014648835]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [date])' />
      </column>
      <column caption='Month-Year Label' datatype='string' name='[Calculation_551409497014931460]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT(DATENAME(&apos;month&apos;,[date]),3)+&quot;&quot;+STR(YEAR([date]))' />
      </column>
      <column caption='Week Number' datatype='integer' name='[Calculation_551409497015394309]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;week&apos;,[date])' />
      </column>
      <column caption='Day of Week' datatype='string' name='[Calculation_551409497015611398]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;,[date])' />
      </column>
      <column caption='Is In Period' datatype='boolean' name='[Calculation_551409497016045575]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;YTD&quot; THEN&#13;&#10;    YEAR([date]) = YEAR([Parameters].[Parameter 2])&#13;&#10;    AND [date] &lt;= [Parameters].[Parameter 2]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;QTD&quot; THEN&#13;&#10;    YEAR([date]) = YEAR([Parameters].[Parameter 2])&#13;&#10;    AND DATEPART(&apos;quarter&apos;,[date]) = DATEPART(&apos;quarter&apos;,[Parameters].[Parameter 2])&#13;&#10;    AND [date] &lt;= [Parameters].[Parameter 2]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;MTD&quot; THEN&#13;&#10;    YEAR([date]) = YEAR([Parameters].[Parameter 2])&#13;&#10;    AND MONTH([date])= MONTH([Parameters].[Parameter 2])&#13;&#10;    AND [date] &lt;= [Parameters].[Parameter 2]&#13;&#10;END' />
      </column>
      <column caption='Period Tickets' datatype='integer' name='[Calculation_551409497017577480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_551409497016045575] THEN 1 ELSE 0 END' />
      </column>
      <column caption='Period Label' datatype='string' name='[Calculation_551409497017769993]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;YTD&quot; THEN &quot;YTD:&quot; + STR(YEAR([Parameters].[Parameter 2]))&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;QTD&quot; THEN &quot;QTD:Q&quot; + STR(DATEPART(&apos;quarter&apos;,[Parameters].[Parameter 2]))+&quot;&quot;+STR(YEAR([Parameters].[Parameter 2]))&#13;&#10;ELSE &quot;MTD:&quot; + DATENAME(&apos;month&apos;,[Parameters].[Parameter 2])+&quot;&quot;+STR(YEAR([Parameters].[Parameter 2]))&#13;&#10;END' />
      </column>
      <column caption='Total Tickets' datatype='integer' name='[Calculation_551409497019093002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([ticket_id])' />
      </column>
      <column caption='High Priority Count' datatype='integer' name='[Calculation_551409497019248651]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [priority] = &quot;high&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='High Priority %' datatype='real' default-format='p0.0%' name='[Calculation_551409497019654156]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_551409497019248651]/COUNT([ticket_id])' />
      </column>
      <column caption='Critical Incident' datatype='integer' name='[Calculation_551409497020076045]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [payment_impact_flag] = 1&#13;&#10;    OR [security_incident_flag] = 1&#13;&#10;    OR [data_loss_flag] = 1&#13;&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='Critical Incident Count' datatype='integer' name='[Calculation_551409497020432398]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_551409497020076045])' />
      </column>
      <column caption='Negative Sentiment %' datatype='real' default-format='p0.0%' name='[Calculation_551409497020563471]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [customer_sentiment] = &quot;negative&quot; THEN 1 ELSE 0 END)/COUNT([ticket_id])' />
      </column>
      <column caption='Positive Sentiment %' datatype='real' name='[Calculation_551409497021026320]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [customer_sentiment] = &quot;positive&quot; THEN 1 ELSE 0 END)/COUNT([ticket_id])' />
      </column>
      <column caption='CSAT Score' datatype='real' default-format='p0.0%' name='[Calculation_551409497021263889]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [customer_sentiment] = &quot;positive&quot; THEN 3&#13;&#10;ELSEIF [customer_sentiment] = &quot;neutral&quot; THEN 2&#13;&#10;ELSE 1 END)/(COUNT([ticket_id])*3))*100' />
      </column>
      <column caption='Avg Error Rate' datatype='real' default-format='p0.0%' name='[Calculation_551409497021943826]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([error_rate_pct])' />
      </column>
      <column caption='Total Downtime Hrs' datatype='real' name='[Calculation_551409497022050323]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([downtime_min])/60' />
      </column>
      <column caption='Runbook Coverage %' datatype='real' default-format='p0.00%' name='[Calculation_551409497022873620]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([has_runbook])/COUNT([ticket_id])' />
      </column>
      <column caption='Priority Color' datatype='string' name='[Calculation_551409497026609173]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [priority] = &quot;high&quot; THEN &quot;High&quot;&#13;&#10;ELSEIF [priority] = &quot;medium&quot; THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;Low&quot;&#13;&#10;END' />
      </column>
      <column caption='Sentiment Label' datatype='string' name='[Calculation_551409497027010582]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [customer_sentiment] = &quot;positive&quot; THEN &quot;Positive&quot;&#13;&#10;ELSEIF [customer_sentiment] = &quot;negative&quot; THEN &quot;Negative&quot;&#13;&#10;ELSE &quot;Neutral&quot;&#13;&#10;END' />
      </column>
      <column caption='Error Rate Status' datatype='string' name='[Calculation_551409497027498007]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([error_rate_pct]) &gt;= 10 THEN &quot;Critical(&gt;=10%)&quot;&#13;&#10;ELSEIF AVG([error_rate_pct]) &gt;= 5 THEN &quot;Warning(5-10%)&quot;&#13;&#10;ELSEIF AVG([error_rate_pct]) &gt;= 2 THEN &quot;Moderate(2-5%)&quot;&#13;&#10;ELSE &quot;Good(&lt;2%)&quot;&#13;&#10;END' />
      </column>
      <column caption='Risk Score' datatype='integer' name='[Calculation_551409497029169176]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[priority_cat]*2&#13;&#10;+([Calculation_551409497020076045]*5)&#13;&#10;+ IF [customer_sentiment] = &quot;negative&quot; THEN 2 ELSE 0 END&#13;&#10;+ IF [error_rate_pct] &gt;= 10 THEN 3&#13;&#10;ELSEIF [error_rate_pct] &gt;= 5 THEN 1&#13;&#10;ELSE 0 END' />
      </column>
      <column caption='KPI Traffic Light' datatype='string' name='[Calculation_551409497029922841]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_551409497020563471] &gt; 0.30 THEN &quot;At Risk&quot;&#13;&#10;ELSEIF [Calculation_551409497020563471] &gt; 0.20 THEN &quot;Caution&quot;&#13;&#10;ELSE &quot;Healthy&quot;&#13;&#10;END' />
      </column>
      <column caption='Selected Metric Value' datatype='real' name='[Calculation_551409497030524954]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 4] = &quot;Customers Affected&quot; THEN SUM([customers_affected])&#13;&#10;ELSEIF [Parameters].[Parameter 4] = &quot;Error Rate %&quot; THEN AVG([error_rate_pct])&#13;&#10;ELSEIF [Parameters].[Parameter 4] = &quot;Downtime(min)&quot; THEN SUM([downtime_min])&#13;&#10;ELSEIF [Parameters].[Parameter 4] = &quot;Ticket Count&quot; THEN COUNT([ticket_id])&#13;&#10;END' />
      </column>
      <column caption='Rank by Tickets' datatype='integer' name='[Calculation_551409497031503899]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(COUNT([ticket_id]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Running Total' datatype='integer' name='[Calculation_551409497031749660]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_SUM(COUNT([ticket_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Moving Avg(3mo)' datatype='real' name='[Calculation_551409497031913501]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(COUNT([ticket_id]),-2,0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Row Index' datatype='integer' name='[Calculation_551409497032183838]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='% of Total' datatype='real' default-format='p0.0%' name='[Calculation_551409497032290335]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([ticket_id])/TOTAL(COUNT([ticket_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Cumalative %' datatype='real' name='[Calculation_551409497032445984]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(COUNT([ticket_id]))/TOTAL(COUNT([ticket_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Industry Display' datatype='string' name='[Calculation_551409497032708129]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [industry] = &quot;saas_b2b&quot; THEN &quot;Saas/B2B&quot;&#13;&#10;ELSEIF [industry] = &quot;ecommerce&quot; THEN &quot;eCommerce&quot;&#13;&#10;ELSEIF [industry] = &quot;fintech&quot; THEN &quot;Fintech&quot;&#13;&#10;ELSEIF [industry] = &quot;healthcare&quot; THEN &quot;Healthcare&quot;&#13;&#10;ELSEIF [industry] = &quot;logistics&quot; THEN &quot;Logistics&quot;&#13;&#10;ELSEIF [industry] = &quot;gaming&quot; THEN &quot;Gaming&quot;&#13;&#10;ELSEIF [industry] = &quot;media&quot; THEN &quot;Media&quot;&#13;&#10;END' />
      </column>
      <column caption='Ticket ID Short' datatype='string' name='[Calculation_551409497033863202]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='RIGHT(STR([ticket_id]),6)' />
      </column>
      <column caption='Company Lifetime Tickets' datatype='integer' name='[Calculation_551409497034014755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [company_id]: COUNT([ticket_id])}' />
      </column>
      <column caption='Industry Avg Error Rate' datatype='integer' name='[Calculation_551409497034223652]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [company_id]:MAX([customers_affected])}' />
      </column>
      <column caption='Country Share of Region' datatype='real' name='[Calculation_551409497034440741]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{INCLUDE [country]:COUNT([ticket_id])}/{FIXED [region]:COUNT([ticket_id])}' />
      </column>
      <column caption='Company First Ticket' datatype='date' name='[Calculation_551409497035022374]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{FIXED [company_id]:MIN([date])}' />
      </column>
      <column caption='Max Affected per Company' datatype='integer' name='[Calculation_551409497035235367]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [company_id]:MAX([customers_affected])}' />
      </column>
      <column caption='Product Area Display' datatype='string' name='[Calculation_551409497035485224]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [product_area] = &quot;auth&quot; THEN &quot;Authentication&quot;&#13;&#10;ELSEIF [product_area] = &quot;billing&quot; THEN &quot;Billing&quot;&#13;&#10;ELSEIF [product_area] = &quot;analytics&quot; THEN &quot;Analytics&quot;&#13;&#10;ELSEIF [product_area] = &quot;data_pipeline&quot; THEN &quot;Data Pipeline&quot;&#13;&#10;ELSEIF [product_area] = &quot;mobile&quot; THEN &quot;Mobile&quot;&#13;&#10;ELSEIF [product_area] = &quot;notifications&quot; THEN &quot;Notifications&quot;&#13;&#10;END' />
      </column>
      <column caption='Sentiment Group' datatype='string' name='[Customer Sentiment (group)]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[customer_sentiment]' new-bin='true'>
          <bin default-name='false' value='&quot;Dissatisfied&quot;'>
            <value>&quot;negative&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Neutral&quot;'>
            <value>&quot;neutral&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Satisfied&quot;'>
            <value>&quot;positive&quot;</value>
          </bin>
        </calculation>
      </column>
      <column aggregation='None' caption='Affected Volume Bins' datatype='integer' name='[Customers Affected (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='2' formula='[customers_affected]' peg='0' size='500' />
      </column>
      <column aggregation='None' caption='Downtime Bins' datatype='integer' name='[Downtime Min (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='1' formula='[downtime_min]' peg='0' size='20' />
      </column>
      <column aggregation='None' caption='Error Rate Bins' datatype='integer' name='[Error Rate Pct (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[error_rate_pct]' peg='0' size='5' />
      </column>
      <column datatype='string' name='[Priority Group]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[priority]' new-bin='true'>
          <bin default-name='false' value='&quot;Non-Critical&quot;'>
            <value>&quot;low&quot;</value>
            <value>&quot;medium&quot;</value>
          </bin>
        </calculation>
      </column>
      <column datatype='string' name='[Size Group]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[company_size]' new-bin='true'>
          <bin default-name='false' value='&quot;Enterprise Scale&quot;'>
            <value>&quot;Large&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;SMB Scale&quot;'>
            <value>&quot;Medium&quot;</value>
            <value>&quot;Small&quot;</value>
          </bin>
        </calculation>
      </column>
