            <datasource caption='Support_tickets (Support_tickets)' name='federated.02q4qsv1gwrutx10fvehz1yh184p' />
          </datasources>
          <datasource-dependencies datasource='federated.02q4qsv1gwrutx10fvehz1yh184p'>
            <column caption='Avg Error Rate' datatype='real' default-format='p0.0%' name='[Calculation_551409497021943826]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([error_rate_pct])' />
            </column>
            <column caption='Error Rate Status' datatype='string' name='[Calculation_551409497027498007]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([error_rate_pct]) &gt;= 10 THEN &quot;Critical(&gt;=10%)&quot;&#13;&#10;ELSEIF AVG([error_rate_pct]) &gt;= 5 THEN &quot;Warning(5-10%)&quot;&#13;&#10;ELSEIF AVG([error_rate_pct]) &gt;= 2 THEN &quot;Moderate(2-5%)&quot;&#13;&#10;ELSE &quot;Good(&lt;2%)&quot;&#13;&#10;END' />
            </column>
            <column caption='Error Rate Pct' datatype='real' name='[error_rate_pct]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_551409497021943826]' derivation='User' name='[usr:Calculation_551409497021943826:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_551409497027498007]' derivation='User' name='[usr:Calculation_551409497027498007:nk]' pivot='key' type='nominal' />
