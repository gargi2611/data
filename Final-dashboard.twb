            <datasource caption='Support_tickets (Support_tickets)' name='federated.02q4qsv1gwrutx10fvehz1yh184p' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Month to Date' caption='Select Time Period' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;MTD&quot;'>
              <calculation class='tableau' formula='&quot;MTD&quot;' />
              <aliases>
                <alias key='&quot;MTD&quot;' value='Month to Date' />
                <alias key='&quot;QTD&quot;' value='Quarter to Date' />
                <alias key='&quot;YTD&quot;' value='Year to Date' />
              </aliases>
            </column>
            <column caption='fdate (Reference Date)' datatype='date' default-format='*m/d/yyyy' name='[Parameter 2]' param-domain-type='range' role='measure' type='quantitative' value='#2026-12-31#'>
              <calculation class='tableau' formula='#2026-12-31#' />
              <range granularity='1' max='#2026-12-31#' min='#2021-01-01#' period-type-v2='day' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.02q4qsv1gwrutx10fvehz1yh184p'>
            <column caption='Period Label' datatype='string' name='[Calculation_551409497017769993]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;YTD&quot; THEN &quot;YTD:&quot; + STR(YEAR([Parameters].[Parameter 2]))&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;QTD&quot; THEN &quot;QTD:Q&quot; + STR(DATEPART(&apos;quarter&apos;,[Parameters].[Parameter 2]))+&quot;&quot;+STR(YEAR([Parameters].[Parameter 2]))&#13;&#10;ELSE &quot;MTD:&quot; + DATENAME(&apos;month&apos;,[Parameters].[Parameter 2])+&quot;&quot;+STR(YEAR([Parameters].[Parameter 2]))&#13;&#10;END' />
            </column>
            <column caption='Total Tickets' datatype='integer' name='[Calculation_551409497019093002]' role='measure' type='quantitative'>
