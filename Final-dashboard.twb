            <column-instance column='[Calculation_551409497017769993]' derivation='None' name='[none:Calculation_551409497017769993:nk]' pivot='key' type='nominal' />
            <column caption='Ticket Id' datatype='integer' name='[ticket_id]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_551409497019093002]' derivation='User' name='[usr:Calculation_551409497019093002:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
